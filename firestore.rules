rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['name', 'score', 'status', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.score is number && data.score >= 0 && data.score <= 1000000 &&
             data.status is string && data.status.size() > 0 && data.status.size() <= 200 &&
             data.createdAt == request.time;
    }

    match /leaderboard/{entryId} {
      allow get: if true;
      allow list: if resource.data.score >= 0;

      allow create: if isValidId(entryId) &&
                    isValidLeaderboardEntry(incoming());

      allow update, delete: if false;
    }

    match /game_data/{docId} {
      allow get: if true;
      allow list: if true;
      allow write: if !exists(/databases/$(database)/documents/game_data/constants);
    }

    match /events/{eventId} {
      allow get: if true;
      allow list: if true;
      allow write: if !exists(/databases/$(database)/documents/game_data/constants);
    }
  }
}
